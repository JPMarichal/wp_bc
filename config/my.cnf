[mysqld]
# Performance
innodb_buffer_pool_size = 256M
innodb_log_file_size    = 64M
innodb_flush_method     = O_DIRECT
innodb_flush_log_at_trx_commit = 2
innodb_file_per_table   = 1

# Disable legacy query cache (removed in MySQL 8.3+)
query_cache_type = 0

# Connections
max_connections = 50
thread_cache_size = 8

# Temp tables
tmp_table_size   = 32M
max_heap_table_size = 32M

# Sorting
sort_buffer_size = 2M
read_buffer_size = 1M

# Logging (minimal for dev)
slow_query_log = 0
log_queries_not_using_indexes = 0
